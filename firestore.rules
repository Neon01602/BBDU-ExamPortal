rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email_verified == true &&
          (request.auth.token.email == "ahmadabdullah007860@gmail.com" ||
           (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
          )
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // Students can update their own profile, but cannot shrink submittedExams (anti-tampering)
      allow update: if isAdmin() ||
        (isOwner(userId) &&
          (
            // submittedExams field is not present in request (not being changed), OR
            !("submittedExams" in request.resource.data) ||
            // submittedExams can only grow — every existing entry must be preserved
            (resource.data.get("submittedExams", []).toSet()
              .difference(request.resource.data.submittedExams.toSet())
              .size() == 0)
          )
        );
    }

    // Questions — any authenticated user can read; only admin writes
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Responses — students write only their own; admin reads all
    match /responses/{responseId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource != null && resource.data.userId == request.auth.uid);

      // Allow create: must be writing your own userId
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      // Allow update: must own the existing doc and the new doc
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;

      allow delete: if false;
    }

    // Exams — any authenticated user can read; only admin writes
    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Admin config
    match /config/admin {
      allow read: if true;
      allow write: if !exists(/databases/$(database)/documents/config/admin) ||
                     get(/databases/$(database)/documents/config/admin).data.isInitialized == false ||
                     isAdmin();
    }
  }
}
